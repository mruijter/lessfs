	$(AM_V_CCLD)$(mklessfs_LINK) $(mklessfs_OBJECTS) $(mklessfs_LDADD) $(LIBS)

replogtool$(EXEEXT): $(replogtool_OBJECTS) $(replogtool_DEPENDENCIES) $(EXTRA_replogtool_DEPENDENCIES) 
	@rm -f replogtool$(EXEEXT)
	$(AM_V_CCLD)$(replogtool_LINK) $(replogtool_OBJECTS) $(replogtool_LDADD) $(LIBS)

mostlyclean-compile:
	-rm -f *.$(OBJEXT)

distclean-compile:
	-rm -f *.tab.c

